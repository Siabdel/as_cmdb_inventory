INVENTORY_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
INVENTORY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INVENTORY_QR_CODE_BASE_URL=http://localhost:8300/assets